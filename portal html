<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HomeReady Portal</title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: #f4f7fb;
      color: #1f2937;
    }

    header {
      background: #0f172a;
      color: white;
      padding: 18px 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    header h1 {
      margin: 0;
      font-size: 24px;
    }

    nav a {
      color: white;
      text-decoration: none;
      margin-left: 18px;
    }

    main {
      max-width: 1100px;
      margin: 40px auto;
      padding: 0 20px;
    }

    .hero {
      background: white;
      border-radius: 16px;
      padding: 28px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      margin-bottom: 24px;
    }

    .hero h2 {
      margin-top: 0;
      font-size: 30px;
    }

    .progress-wrap {
      margin-top: 20px;
    }

    .progress-bar {
      width: 100%;
      height: 18px;
      background: #e5e7eb;
      border-radius: 999px;
      overflow: hidden;
    }

    .progress-fill {
      width: 65%;
      height: 100%;
      background: #2563eb;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
    }

    .card {
      background: white;
      border-radius: 16px;
      padding: 22px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    }

    .card h3 {
      margin-top: 0;
    }

    .card button {
      background: #2563eb;
      color: white;
      border: none;
      padding: 12px 16px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: bold;
    }

    .card button:hover {
      background: #1d4ed8;
    }

    ul {
      padding-left: 20px;
    }

    .status {
      display: inline-block;
      background: #dcfce7;
      color: #166534;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 14px;
      font-weight: bold;
    }

    footer {
      text-align: center;
      padding: 30px;
      color: #64748b;
    }
  </style>
</head>

<body>
  <header>
    <h1>HomeReady</h1>

    <nav>
      <a href="index.html">Home</a>
      <a href="dashboard.html">Agent Dashboard</a>
      <a href="portal.html">My Portal</a>
    </nav>
  </header>

  <main>
    <section class="hero">
      <span class="status">Buyer Profile Active</span>

      <h2>Welcome to your HomeReady portal</h2>

      <p>
        Complete your profile, organize your documents, and prepare to connect
        with a trusted real estate professional.
      </p>

      <div class="progress-wrap">
        <p><strong>Readiness progress: 65%</strong></p>

        <div class="progress-bar">
          <div class="progress-fill"></div>
        </div>
      </div>
    </section>

    <section class="grid">
      <article class="card">
        <h3>Profile</h3>
        <p>Update your income range, home budget, location, and timeline.</p>
        <button onclick="showMessage('Profile section coming next.')">
          Continue profile
        </button>
      </article>

      <article class="card">
        <h3>Document Center</h3>
        <p>Keep your home-buying documents organized in one place.</p>

        <input
          type="file"
          id="documentUpload"
          accept=".pdf,.png,.jpg,.jpeg"
        />

        <p id="fileMessage">No sample document selected.</p>
      </article>

      <article class="card">
        <h3>Next Steps</h3>

        <ul>
          <li>Complete financial readiness details</li>
          <li>Add preferred home location</li>
          <li>Upload a preapproval letter</li>
          <li>Request an agent review</li>
        </ul>
      </article>

      <article class="card">
        <h3>Agent Connection</h3>
        <p>
          When your profile is ready, request a review from a participating
          real estate professional.
        </p>

        <button onclick="requestAgent()">
          Request an agent
        </button>

        <p id="agentMessage"></p>
      </article>
    </section>
  </main>

  <footer>
    HomeReady readiness tools are informational and do not represent loan approval.
  </footer>

  <script>
    const documentUpload = document.getElementById("documentUpload");
    const fileMessage = document.getElementById("fileMessage");
    const agentMessage = document.getElementById("agentMessage");

    documentUpload.addEventListener("change", function () {
      const file = documentUpload.files[0];

      if (!file) {
        fileMessage.textContent = "No sample document selected.";
        return;
      }

      fileMessage.textContent =
        file.name + " is selected but has not been uploaded.";
    });

    function requestAgent() {
      agentMessage.textContent =
        "Your agent request has been prepared for review.";
    }

    function showMessage(message) {
      alert(message);
    }
  </script>
</body>
</html>
